{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yukkuricast.local/schema/yukkuricast-script.schema.json",
  "title": "YukkuriCast Script",
  "type": "object",
  "required": ["format", "version", "project", "characters", "scenes"],
  "properties": {
    "format": { "const": "yukkuricast-script" },
    "version": { "const": "1.0" },
    "project": {
      "type": "object",
      "required": ["title", "fps", "resolution", "theme"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "fps": { "type": "integer", "minimum": 12, "maximum": 60, "default": 30 },
        "resolution": {
          "type": "object",
          "required": ["width", "height"],
          "properties": {
            "width": { "type": "integer", "minimum": 640, "maximum": 3840 },
            "height": { "type": "integer", "minimum": 360, "maximum": 2160 }
          }
        },
        "theme": {
          "type": "object",
          "required": ["palette", "subtitleStyle"],
          "properties": {
            "palette": { "enum": ["studio-dark", "paper-light", "cyber-classroom"] },
            "subtitleStyle": { "enum": ["pop", "news", "minimal"] },
            "bgm": { "enum": ["none", "soft", "news", "tech"] }
          }
        }
      }
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["id", "name", "asset", "side", "voice"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-zA-Z0-9_-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "asset": { "enum": ["akari", "kohaku", "aoba", "custom"] },
          "customAsset": {
            "type": "object",
            "required": ["id", "label", "filePath"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 },
              "filePath": { "type": "string", "minLength": 1 },
              "previewUrl": { "type": "string" },
              "importedAt": { "type": "string" }
            }
          },
          "defaultEmotion": { "enum": ["neutral", "happy", "thinking", "surprised", "serious"] },
          "side": { "enum": ["left", "right"] },
          "voice": {
            "type": "object",
            "required": ["engine"],
            "properties": {
              "engine": { "enum": ["windows-sapi", "aquestalk-player"] },
              "voiceName": { "type": "string" },
              "aquestalkPreset": { "type": "string" },
              "rate": { "type": "integer", "minimum": -10, "maximum": 10 },
              "volume": { "type": "integer", "minimum": 0, "maximum": 100 }
            }
          }
        }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "background", "shots"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "summary": { "type": "string" },
          "background": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "enum": ["gradient", "solid", "grid"] },
              "from": { "$ref": "#/$defs/color" },
              "to": { "$ref": "#/$defs/color" },
              "color": { "$ref": "#/$defs/color" },
              "accent": { "$ref": "#/$defs/color" }
            }
          },
          "shots": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "speakerId", "text", "duration"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "speakerId": { "type": "string", "minLength": 1 },
                "text": { "type": "string", "minLength": 1 },
                "duration": { "type": "number", "minimum": 1, "maximum": 45 },
                "emotion": { "enum": ["neutral", "happy", "thinking", "surprised", "serious"] },
                "layout": { "enum": ["duo", "left-focus", "right-focus", "solo-center"] },
                "caption": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "emphasis": { "type": "array", "items": { "type": "string" } },
                    "position": { "enum": ["bottom", "center"] }
                  }
                },
                "visuals": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["type", "title"],
                    "properties": {
                      "type": { "enum": ["image", "keyword", "bullet", "chart", "code"] },
                      "title": { "type": "string", "minLength": 1 },
                      "body": { "type": "string" },
                      "items": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                },
                "notes": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "color": {
      "type": "string",
      "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"
    }
  }
}
